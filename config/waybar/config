{
  "position": "top",
  "modules-left": [
    "hyprland/workspaces",
    "hyprland/submap"
  ],
  "modules-center": [
    "clock",
    "pulseaudio"
  ],
  "modules-right": [
    "cpu",
    "memory",
    "custom/power"
  ],
  "custom/cpu-graph": {
    "exec": "$HOME/.config/waybar/scripts/cpu-graph.sh",
    "interval": 1,
    "return-type": "markup",
    "tooltip": false
  },
  "clock": {
    "format": "{:%d-%m %H:%M}",
    "tooltip-format": "<big>{:%a %d-%m-%Y}</big>"
  },
  "custom/external-ip": {
    "exec": "curl -s https://ipinfo.io/ip",
    "interval": 30,
    "on-click": "curl -s https://ipinfo.io/ip | xsel --clipboard --input"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "<span size='13000' foreground='#a6e3a1'>{icon} </span> {capacity}%",
    "format-warning": "<span size='13000' foreground='#B1E3AD'>{icon} </span> {capacity}%",
    "format-critical": "<span size='13000' foreground='#E38C8F'>{icon} </span> {capacity}%",
    "format-charging": "<span size='13000' foreground='#B1E3AD'>’ć” </span>{capacity}%",
    "format-plugged": "<span size='13000' foreground='#B1E3AD'>’ć” </span>{capacity}%",
