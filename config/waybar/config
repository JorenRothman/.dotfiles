{
  "position": "top",
  "modules-left": [
    "hyprland/workspaces",
    "hyprland/submap"
  ],
  "modules-center": [
    "clock",
    "pulseaudio"
  ],
  "modules-right": [
    "cpu",
    "memory",
    "custom/vpn",
    "custom/external-ip",
    "custom/power"

  ],
  "custom/cpu-graph": {
    "exec": "$HOME/.config/waybar/scripts/cpu-graph.sh",
    "interval": 1,
    "return-type": "markup",
    "tooltip": false
  },
  "clock": {
    "format": "{:%d-%m %H:%M}",
    "tooltip-format": "<big>{:%a %d-%m-%Y}</big>"
  },
  "custom/external-ip": {
    "exec": "curl -s https://ipinfo.io/ip",
    "interval": 30,
    "on-click": "curl -s https://ipinfo.io/ip | xsel --clipboard --input"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "<span size='13000' foreground='#a6e3a1'>{icon} </span> {capacity}%",
    "format-warning": "<span size='13000' foreground='#B1E3AD'>{icon} </span> {capacity}%",
    "format-critical": "<span size='13000' foreground='#E38C8F'>{icon} </span> {capacity}%",
    "format-charging": "<span size='13000' foreground='#B1E3AD'>яЗж </span>{capacity}%",
    "format-plugged": "<span size='13000' foreground='#B1E3AD'>яЗж </span>{capacity}%",
    "format-alt": "<span size='13000' foreground='#B1E3AD'>{icon} </span> {time}",
    "format-full": "<span size='13000' foreground='#B1E3AD'>яАД </span>{capacity}%",
    "format-icons": [
      "яЙД",
      "яЙГ",
      "яЙВ",
      "яЙБ",
      "яЙА"
    ],
    "tooltip-format": "{time}"
  },
  "network": {
    "format-wifi": "<span size='13000' foreground='#f5e0dc'>яЗл  </span>{essid}",
    "format-ethernet": "{ifname}",
    "format-linked": "{ifname} (No IP) яЮЦ",
    "format-disconnected": "<span size='13000' foreground='#f5e0dc'>яБк  </span>Disconnected",
  },
  "pulseaudio": {
    "scroll-step": 3,
    "format": "{icon} {volume}% {format_source}",
    "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
    "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
    "format-muted": "яЪй {format_source}",
    "format-source": "яД░",
    "format-source-muted": "яД▒",
    "format-icons": {
      "headphone": "яАе",
      "hands-free": "яЦР",
      "headset": "яЦР",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": [
        "яАж",
        "яАз",
        "яАи  "
      ]
    },
    "on-click": "pavucontrol",
    "on-click-right": "amixer sset Master toggle"
  },
  "custom/media": {
    "format": "{0} ",
    "return-type": "json",
    "max-length": 64,
    "format-icons": {
      "spotify": "яЖ╝",
      "default": "ЁЯОЬ"
    },
    "escape": true,
    "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null"
  },
  "custom/power": {
    "format": "яАС",
    "tooltip": false,
    "on-click": "wlogout -l $HOME/.config/wlogout/layout"
  },
  "memory": {
    "interval": 30,
    "format": "RAM: {used:0.2f} / {total:0.0f} GB",
    "on-click": "alacritty -e btop"
  },
  "cpu": {
    "interval": 1,
    "format": "CPU: {usage}%",
    "max-length": 13,
    "min-length": 13
  },
  "custom/notes": {
    "exec": "~/.config/waybar/scripts/notes.sh",
    "interval": 30,
    "format": "IPs",
    "on-click": "code ~/.config/waybar/notes/notes.txt"
  },
  "custom/vpn": {
    "interval": 3,
    "format": "{}",
    "exec": "ip add show | grep -qF Joren-Linux && echo ЁЯФТ Connected || echo ЁЯФУ Disconnected",
    "max-length": "100",
    "on-click": "nmcli connection up WireGuard",
    "on-click-right": "nmcli connection down WireGuard",
    "on-click-middle": "wl-copy 162.55.40.2",
    "tooltip": true,
    "tooltip-format": "162.55.40.2"
  }
}
