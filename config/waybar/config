  "custom/media": {
    "format": "{0} ",
    "return-type": "json",
    "max-length": 64,
    "format-icons": {
      "spotify": "’å╝",
      "default": "­¤Ä£"
    },
    "escape": true,
    "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null"
  },
  "custom/power": {
    "format": "’Ćæ",
    "tooltip": false,
    "on-click": "wlogout -l $HOME/.config/wlogout/layout"
