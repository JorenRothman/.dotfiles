{
  "position": "top",
  "modules-left": [
    "hyprland/workspaces",
    "hyprland/submap"
  ],
  "modules-center": [
    "clock",
    "pulseaudio"
  ],
  "modules-right": [
    "cpu",
    "memory",
    "custom/notes",
    "custom/power"
  ],
  "custom/cpu-graph": {
    "exec": "$HOME/.config/waybar/scripts/cpu-graph.sh",
    "interval": 1,
    "return-type": "markup",
    "tooltip": false
  },
  "clock": {
    "format": "{:%d-%m %H:%M}",
    "tooltip-format": "<big>{:%a %d-%m-%Y}</big>"
  },
  "custom/external-ip": {
    "exec": "curl -s https://ipinfo.io/ip",
    "interval": 30,
    "on-click": "curl -s https://ipinfo.io/ip | xsel --clipboard --input"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "<span size='13000' foreground='#a6e3a1'>{icon} </span> {capacity}%",
    "format-warning": "<span size='13000' foreground='#B1E3AD'>{icon} </span> {capacity}%",
    "format-critical": "<span size='13000' foreground='#E38C8F'>{icon} </span> {capacity}%",
    "format-charging": "<span size='13000' foreground='#B1E3AD'>´çŽ </span>{capacity}%",
    "format-plugged": "<span size='13000' foreground='#B1E3AD'>´çŽ </span>{capacity}%",
    "format-alt": "<span size='13000' foreground='#B1E3AD'>{icon} </span> {time}",
    "format-full": "<span size='13000' foreground='#B1E3AD'>´Çä </span>{capacity}%",
    "format-icons": [
      "´ëä",
      "´ëâ",
      "´ëé",
      "´ëü",
      "´ëÇ"
    ],
    "tooltip-format": "{time}"
  },
  "network": {
    "format-wifi": "<span size='13000' foreground='#f5e0dc'>´çź  </span>{essid}",
    "format-ethernet": "<span size='13000' foreground='#f5e0dc'>ˇ░Ąş  </span> Disconnected",
    "format-linked": "{ifname} (No IP) ´×ľ",
    "format-disconnected": "<span size='13000' foreground='#f5e0dc'>´ü¬  </span>Disconnected",
    "tooltip-format-wifi": "Signal Strenght: {signalStrength}%"
  },
  "pulseaudio": {
    "scroll-step": 3,
    "format": "{icon} {volume}% {format_source}",
    "format-bluetooth": "{volume}% {icon}´Őö {format_source}",
    "format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
    "format-muted": "´Üę {format_source}",
    "format-source": "´ä░",
    "format-source-muted": "´ä▒",
    "format-icons": {
      "headphone": "´Çą",
      "hands-free": "´ľÉ",
      "headset": "´ľÉ",
      "phone": "´éĽ",
      "portable": "´éĽ",
      "car": "´ć╣",
      "default": [
        "´ÇŽ",
        "´Çž",
        "´ÇĘ  "
      ]
    },
    "on-click": "pavucontrol",
    "on-click-right": "amixer sset Master toggle"
  },
  "custom/media": {
    "format": "{0} ",
    "return-type": "json",
    "max-length": 64,
    "format-icons": {
      "spotify": "´ć╝",
      "default": "­čÄť"
    },
    "escape": true,
    "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null"
  },
  "custom/power": {
    "format": "´ÇĹ",
    "tooltip": false,
    "on-click": "wlogout -l $HOME/.config/wlogout/layout"
  },
  "memory": {
    "interval": 30,
    "format": "RAM: {used:0.2f} / {total:0.0f} GB",
    "on-click": "alacritty -e btop"
  },
  "cpu": {
    "interval": 1,
    "format": "CPU: {usage}%",
    "max-length": 13,
    "min-length": 13
  },
  "custom/notes": {
    "exec": "~/.config/waybar/scripts/notes.sh",
    "interval": 30,
    "format": "IPs",
    "on-click": "code ~/.config/waybar/notes/notes.txt"
  }
}
