# ~/.zshrc — frameworkless zsh config
# Plugins are git submodules in the dotfiles (shared/zsh/plugins), symlinked
# here by dotbot so the path is the same on every machine.
ZSH_PLUGIN_DIR=${XDG_CONFIG_HOME:-$HOME/.config}/zsh/plugins

# -----------------
# Zsh options
# -----------------
setopt HIST_IGNORE_ALL_DUPS    # drop older duplicate when adding a command
setopt HIST_IGNORE_SPACE       # don't record commands starting with a space
setopt SHARE_HISTORY           # share history across running shells
setopt EXTENDED_HISTORY        # record timestamp per command
setopt INTERACTIVE_COMMENTS    # allow # comments in interactive shell
setopt AUTO_CD                 # `dir` instead of `cd dir`

HISTFILE=${HOME}/.zsh_history
HISTSIZE=50000
SAVEHIST=50000

# Editor keymap: emacs (`-e`) or vi (`-v`).
bindkey -e

# Remove path separator from WORDCHARS so word movement stops at `/`.
WORDCHARS=${WORDCHARS//[\/]}

# -----------------
# Completion
# -----------------
fpath=(${ZSH_PLUGIN_DIR}/zsh-completions/src $fpath)

autoload -Uz compinit
# Only run the full (slow) security check once per day; otherwise reuse cache.
_zcompdump=${ZDOTDIR:-$HOME}/.zcompdump
if [[ -n ${_zcompdump}(#qNmh+24) ]]; then
  compinit -d ${_zcompdump}
else
  compinit -C -d ${_zcompdump}
fi
unset _zcompdump

zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'   # case-insensitive

# -----------------
# Plugins
# -----------------

# fzf-powered tab completion (load after compinit + completion zstyles, before
# syntax-highlighting). Replaces the default completion menu with an fzf picker.
zstyle ':completion:*:descriptions' format '[%d]'   # group header fzf-tab uses
zstyle ':fzf-tab:*' use-fzf-default-opts yes        # inherit your FZF_DEFAULT_OPTS
zstyle ':fzf-tab:*' fzf-bindings 'tab:accept'       # second Tab accepts selection
zstyle ':fzf-tab:*' continuous-trigger '/'          # '/' descends into next dir level
source ${ZSH_PLUGIN_DIR}/fzf-tab/fzf-tab.plugin.zsh

# Fish-like autosuggestions.
ZSH_AUTOSUGGEST_MANUAL_REBIND=1
source ${ZSH_PLUGIN_DIR}/zsh-autosuggestions/zsh-autosuggestions.zsh

# Fish-like syntax highlighting (must be sourced before history-substring-search).
ZSH_HIGHLIGHT_HIGHLIGHTERS=(main brackets)
source ${ZSH_PLUGIN_DIR}/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# Fish-like history search on up/down (after syntax highlighting).
source ${ZSH_PLUGIN_DIR}/zsh-history-substring-search/zsh-history-substring-search.zsh
zmodload -F zsh/terminfo +p:terminfo
for key ('^[[A' '^P' ${terminfo[kcuu1]}) bindkey ${key} history-substring-search-up
for key ('^[[B' '^N' ${terminfo[kcud1]}) bindkey ${key} history-substring-search-down
for key ('k') bindkey -M vicmd ${key} history-substring-search-up
for key ('j') bindkey -M vicmd ${key} history-substring-search-down
unset key

# Remind when an alias exists for the just-typed command.
source ${ZSH_PLUGIN_DIR}/zsh-you-should-use/you-should-use.plugin.zsh

# -----------------
# User configuration
# -----------------
for conf in "$HOME/.config/zsh/config.d/"*.zsh(N); do
  source "${conf}"
done
for conf in "$HOME/.config/zsh/config.d/mac/"*.zsh(N); do
  source "${conf}"
done
unset conf

# bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# -----------------
# Prompt & tools
# -----------------
eval "$(starship init zsh)"

if command -v vivid >/dev/null 2>&1; then
  export LS_COLORS="$(vivid generate catppuccin-macchiato)"
fi

# zoxide must be initialized last. Disable its doctor check: it false-positives
# in non-interactive / wrapped `cd` contexts even though init is genuinely last.
export _ZO_DOCTOR=0
eval "$(zoxide init --cmd cd zsh)"
